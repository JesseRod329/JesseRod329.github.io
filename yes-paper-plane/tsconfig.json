{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@scenes/*": ["src/scenes/*"],
      "@systems/*": ["src/systems/*"],
      "@assets/*": ["src/assets/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src"]
}












